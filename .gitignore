.venv/
__pycache__/
.Python
*.egg-info/
.eggs/
dist/
build/

# Originales pesados: nunca en el repositorio. Solo se versiona .gitkeep para conservar la ruta acordada.
.assets-raw/*
!.assets-raw/.gitkeep

# Evidencias de laboratorio (vídeos, capturas): no se versionan
laboratorio/evidencias/*
!laboratorio/evidencias/.gitkeep

# Copias de seguridad locales
backups/

# Enlaces simbólicos de infraestructura CMS (no versionables)
public/blog

# Secretos y variables de entorno local (Shift-Left Security)
.env
.linkedin_token.json

# Base de conocimiento personal y privada (Defensa de arquitectura)
.privado/
!.privado/.gitkeep
docs/matriz/
!docs/matriz/.gitkeep

# Manuales locales en PDF (Protege los PDFs legítimos generados por el SSG en otras carpetas)
docs/*.pdf
